# be-bridge configuration

# Server
HOST=127.0.0.1
PORT=1122

# API Key Authentication
# Set this to a secure random string. Must match BRIDGE_API_KEY in be-main.
BRIDGE_API_KEY=your-secure-api-key-here

# Workers
NUM_WORKERS=2

# Browser
BRIDGE_PREFERRED_BROWSER=chrome
BRIDGE_HIDE_CHAT_WINDOW=true
BRIDGE_LAUNCH_MINIMIZED=true
BRIDGE_LAUNCH_OFFSCREEN=false
BRIDGE_HIDDEN_WINDOW_X=-50000
BRIDGE_HIDDEN_WINDOW_Y=-50000

# Chrome profile directory (optional)
# BRIDGE_PROFILE_DIR=./.bridge-chrome-profile

# Chat URL
CHAT_URL=https://chatgpt.com/?temporary-chat=true

# Streaming Detection Tuning
# Số lần check text không đổi trước khi dừng (mỗi lần = 200ms)
# Giá trị nhỏ = dừng nhanh nhưng có thể cắt sớm, giá trị lớn = chắc chắn hơn nhưng chậm
STREAM_NO_CHANGE_THRESHOLD=10

# Fallback timeout khi không phát hiện được generating flag (số lần check)
# Dùng cho ChatGPT UI mới không có selector đúng
STREAM_FALLBACK_THRESHOLD=25

# Timeout tối đa cho toàn bộ streaming (milliseconds)
STREAM_MAX_TIMEOUT=120000

# Timeout đợi response bắt đầu (milliseconds)
STREAM_START_TIMEOUT=10000

# Interval giữa các lần check (milliseconds)
STREAM_CHECK_INTERVAL=200
