# Bridge System Configuration

# ============================================
# BACKEND (be-bridge) — Port: 1110
# ============================================

# Dia chi va cong lang nghe cua be-bridge API server
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=1110

# Key xac thuc duoc quan ly qua Admin Dashboard (bridge/be-bridge/keys.json)

# Tai khoan dang nhap Admin Dashboard (ui-bridge)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# So luong worker (tab ChatGPT chay song song)
BRIDGE_NUM_WORKERS=1

# Trinh duyet Puppeteer su dung (chrome | edge)
BRIDGE_PREFERRED_BROWSER=chrome

# An cua so trinh duyet khi chay
BRIDGE_HIDE_WINDOW=true

# Khoi dong trinh duyet o trang thai thu nho
BRIDGE_LAUNCH_MINIMIZED=true

# Chay trinh duyet ngoai man hinh (toa do am)
BRIDGE_LAUNCH_OFFSCREEN=false
BRIDGE_HIDDEN_WINDOW_X=-50000
BRIDGE_HIDDEN_WINDOW_Y=-50000

# Thu muc luu profile Chrome/Edge
BRIDGE_PROFILE_DIR=D:\BaiTapSinhVien\ThucTapCNX\ChatBotPCCC24-7\bridge\be-bridge\.bridge-chrome-profile

# URL trang ChatGPT Puppeteer se mo
BRIDGE_CHAT_URL=https://chatgpt.com/?temporary-chat=true

# ---- Streaming detection tuning ----
# So lan kiem tra khong co thay doi truoc khi coi la xong
BRIDGE_STREAM_NO_CHANGE_THRESHOLD=10

# So lan fallback truoc khi tra ve ket qua hien tai
BRIDGE_STREAM_FALLBACK_THRESHOLD=25

# Thoi gian cho toi da cho toan bo response (ms)
BRIDGE_STREAM_MAX_TIMEOUT=120000

# Thoi gian cho bat dau co du lieu dau tien (ms)
BRIDGE_STREAM_START_TIMEOUT=30000

# Khoang thoi gian giua moi lan kiem tra stream (ms)
BRIDGE_STREAM_CHECK_INTERVAL=200

# ============================================
# FRONTEND (ui-bridge) — Port: 1111
# ============================================

# Cong chay Admin Dashboard (doc boi run.mjs)
UI_BRIDGE_PORT=1111

# URL cua be-bridge ma ui-bridge se goi
NEXT_PUBLIC_BRIDGE_API_URL=http://localhost:1110

# ============================================
# GLOBAL
# ============================================

NODE_ENV=development
LOG_LEVEL=info








