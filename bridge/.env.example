# Bridge System Configuration
# Standalone module - có thể tái sử dụng ở dự án khác

# ============================================
# BACKEND (be-bridge)
# ============================================

# Server
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=1122

# API Keys
BRIDGE_API_KEY=your_bridge_api_key_here
# Must match NEXT_PUBLIC_ADMIN_API_KEY in this file (after sync) for the admin UI
BRIDGE_ADMIN_API_KEY=bridge_admin_default_key

# Admin login (username/password cho ui-bridge)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Workers
BRIDGE_NUM_WORKERS=2

# Browser
BRIDGE_PREFERRED_BROWSER=chrome
BRIDGE_HIDE_WINDOW=true
BRIDGE_LAUNCH_MINIMIZED=true
BRIDGE_LAUNCH_OFFSCREEN=false
BRIDGE_HIDDEN_WINDOW_X=-50000
BRIDGE_HIDDEN_WINDOW_Y=-50000
BRIDGE_PROFILE_DIR=.bridge-chrome-profile

# Chat
BRIDGE_CHAT_URL=https://chatgpt.com/?temporary-chat=true

# Streaming
BRIDGE_STREAM_NO_CHANGE_THRESHOLD=10
BRIDGE_STREAM_FALLBACK_THRESHOLD=25
BRIDGE_STREAM_MAX_TIMEOUT=120000
BRIDGE_STREAM_START_TIMEOUT=10000
BRIDGE_STREAM_CHECK_INTERVAL=200

# ============================================
# FRONTEND (ui-bridge)
# ============================================

UI_BRIDGE_PORT=3002
NEXT_PUBLIC_BRIDGE_API_URL=http://localhost:1122
NEXT_PUBLIC_ADMIN_API_KEY=bridge_admin_default_key

# ============================================
# GLOBAL
# ============================================

NODE_ENV=development
LOG_LEVEL=info
