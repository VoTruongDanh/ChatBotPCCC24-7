# PCCC Consult Web - Root Environment
# Copy file này thành .env và điền giá trị thực

# ============================================
# BE-BRIDGE (Port 1122)
# ============================================
# HOST=127.0.0.1
# PORT=1122
# NUM_WORKERS=2
# CHAT_URL=https://chatgpt.com/?temporary-chat=true
# BRIDGE_PREFERRED_BROWSER=chrome

# ============================================
# BE-MAIN (Port 3001)
# ============================================
# HOST=127.0.0.1
# PORT=3001
# BRIDGE_URL=http://127.0.0.1:1122

# ============================================
# UI (Port 3000)
# ============================================
# NEXT_PUBLIC_API_URL=http://localhost:3001
