# ============================================
# FRONTEND (ui)
# ============================================

UI_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:6969

# ============================================
# GLOBAL
# ============================================

NODE_ENV=development
LOG_LEVEL=info
