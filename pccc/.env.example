# PCCC System Configuration
# Hệ thống tư vấn Phòng cháy chữa cháy

# ============================================
# BACKEND (be-main)
# ============================================

# Server
MAIN_HOST=127.0.0.1
MAIN_PORT=6969

# Bridge Connection
BRIDGE_URL=http://localhost:1122
BRIDGE_API_KEY=your_bridge_api_key_here
