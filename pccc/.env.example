# PCCC System Configuration
# He thong tu van Phong chay chua chay

# ============================================
# BACKEND (be-main) — Port: 8888
# ============================================

# Dia chi va cong lang nghe cua be-main API server
MAIN_HOST=127.0.0.1
MAIN_PORT=8888

# URL ket noi toi be-bridge
BRIDGE_URL=http://localhost:1110

# Key xac thuc - phai khop voi BRIDGE_API_KEY trong bridge/.env
BRIDGE_API_KEY=bridge_18600b6e6cc84db0a88252893df92f7b

# Thoi gian cho toi da khi goi be-bridge (ms)
BRIDGE_TIMEOUT=30000

# ============================================
# FRONTEND (ui) — Port: 8889
# ============================================

# Cong chay giao dien nguoi dung (doc boi run.mjs)
UI_PORT=8889

# URL cua be-main ma ui se goi
NEXT_PUBLIC_API_URL=http://localhost:8888

# ============================================
# GLOBAL
# ============================================

NODE_ENV=development
LOG_LEVEL=info





